# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Found in: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# ── Stripe ────────────────────────────────────────────────────────────────────
# Found in: dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Price IDs — Stripe dashboard → Products → copy "Price ID"
STRIPE_PRO_PRICE_ID=
STRIPE_SENTINEL_PRICE_ID=

# ── App ───────────────────────────────────────────────────────────────────────
# URL de production (pour les redirects Stripe)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ── Brevo (emails d'alerte) ───────────────────────────────────────────────────
# Found in: app.brevo.com → Settings → API Keys
# Si absent, les emails d'alerte sont désactivés (aucun crash)
BREVO_API_KEY=

# ── cTrader Open API ──────────────────────────────────────────────────────────
# Found in: openapi.ctrader.com → My Apps
CTRADER_CLIENT_ID=
CTRADER_CLIENT_SECRET=
CTRADER_REDIRECT_URI=https://getcaldra.com/api/ctrader/callback
