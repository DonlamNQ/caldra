# Supabase (service role — accès complet, jamais exposer côté client)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# cTrader Open API — mêmes identifiants que l'app (openapi.ctrader.com → My Apps)
CTRADER_CLIENT_ID=xxxx
CTRADER_CLIENT_SECRET=xxxx

# Environnement cTrader : 'live' (défaut) ou 'demo'
# → détermine l'hôte (live.ctraderapi.com / demo.ctraderapi.com) et le filtre de comptes
CTRADER_ENV=live

# Endpoint d'ingestion Caldra (défaut : https://getcaldra.com/api/ingest)
CALDRA_INGEST_URL=https://getcaldra.com/api/ingest
