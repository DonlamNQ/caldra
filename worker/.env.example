# Supabase (service role — accès complet, jamais exposer côté client)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# cTrader Open API — mêmes identifiants que l'app (openapi.ctrader.com → My Apps)
CTRADER_CLIENT_ID=xxxx
CTRADER_CLIENT_SECRET=xxxx

# Environnement cTrader (OPTIONNEL) — laisser VIDE en prod.
# Vide → le worker gère démo ET live dans le même processus (recommandé).
# 'demo' ou 'live' → restreint à un seul environnement.
# ⚠️ NE PAS lancer deux workers (un demo + un live) : ils se partageraient le même
#    jeton OAuth et la rotation concurrente du refresh_token ferait révoquer
#    l'autorisation cTrader par le serveur. Un seul service Railway suffit.
CTRADER_ENV=

# Endpoint d'ingestion Caldra (défaut : https://getcaldra.com/api/ingest)
CALDRA_INGEST_URL=https://getcaldra.com/api/ingest
